# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Frontend (Node/Vite)
frontend/node_modules
frontend/dist
frontend/dist-ssr
frontend/.wrangler
*.local

# Env vars (see frontend/.env.example for the required keys)
frontend/.env
frontend/.env.*
!frontend/.env.example

# Backend (Python)
backend/venv
backend/__pycache__
**/__pycache__
*.pyc
.env

# Backend runtime/generated data
backend/detectados
backend/resultados
backend/runs

# TensorRT engines: compiled for the exact GPU/driver/CUDA version that
# built them, not portable across machines - regenerate locally with
# model.export(format="engine", device=0), see README.md
*.engine

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
